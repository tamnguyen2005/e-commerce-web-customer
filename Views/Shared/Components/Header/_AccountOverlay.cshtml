@model HeaderAccountViewModel

@if (Model.IsLoggedIn)
{
    <div class="site-account-layer"
         data-account-layer
         hidden>
        <button class="site-account-backdrop"
                type="button"
                aria-label="Đóng tài khoản"
                data-account-close></button>

        <section class="site-account-panel"
                 id="site-account-panel"
                 aria-label="Thông báo tài khoản"
                 data-account-panel>
            <div class="site-account-state">
                <a class="site-account-member-card" href="@Model.MemberUrl">
                    <span class="site-account-member-logo">
                        <img src="@Model.MemberLogoUrl"
                             alt="TechStore Smember"
                             width="34"
                             height="34"
                             loading="lazy" />
                    </span>
                    <span class="site-account-member-title">Truy cập Smember</span>
                    <svg class="site-account-member-arrow" width="18" height="18" aria-hidden="true">
                        <use href="#hero-icon-chevron"></use>
                    </svg>
                </a>

                <header class="site-account-notice-header">
                    <h3>Thông báo</h3>
                    <p>@Model.ReadStatusText</p>
                </header>

                <div class="site-account-filter-row"
                     role="tablist"
                     aria-label="Lọc thông báo">
                    <button class="site-account-filter is-active"
                            type="button"
                            role="tab"
                            aria-selected="true"
                            data-account-filter="all">
                        Tất cả
                    </button>
                    <button class="site-account-filter"
                            type="button"
                            role="tab"
                            aria-selected="false"
                            data-account-filter="orders">
                        Đơn hàng
                    </button>
                </div>

                @if (Model.HasNotifications)
                {
                    <div class="site-account-notification-list" data-account-notification-list>
                        @foreach (var notification in Model.Notifications)
                        {
                            <article class="site-account-notification"
                                     data-account-notification
                                     data-account-category="@notification.Category">
                                <span class="site-account-notification-icon" aria-hidden="true">
                                    <svg width="34" height="34">
                                        <use href="#hero-icon-cart"></use>
                                    </svg>
                                    <span class="site-account-notification-check"></span>
                                </span>

                                <div class="site-account-notification-copy">
                                    <p>
                                        <span>@notification.LeadText </span>
                                        <strong>@notification.HighlightText</strong>
                                        <span> @notification.TailText</span>
                                    </p>

                                    <div class="site-account-notification-meta">
                                        <time>@notification.TimeAgoText</time>
                                        <a href="@notification.DetailUrl">Xem chi tiết</a>
                                    </div>
                                </div>
                            </article>
                        }
                    </div>
                }
                else
                {
                    <div class="site-account-empty" data-account-empty>
                        <img src="@Model.MemberLogoUrl"
                             alt="TechStore"
                             width="54"
                             height="54"
                             loading="lazy" />
                        <p>Bạn chưa có thông báo mới.</p>
                    </div>
                }

                <footer class="site-account-panel-footer">
                    <button class="site-account-close-button"
                            type="button"
                            data-account-close>
                        Đóng
                    </button>

                    <form asp-controller="Account"
                          asp-action="Logout"
                          method="post"
                          class="site-account-logout-form">
                        <button class="site-account-logout-button" type="submit">
                            Đăng xuất
                        </button>
                    </form>
                </footer>
            </div>
        </section>
    </div>
}
