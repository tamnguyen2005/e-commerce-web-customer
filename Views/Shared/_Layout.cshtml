<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="@(ViewData["MetaDescription"] ?? "TechStore - Mua sắm điện thoại, laptop, phụ kiện chính hãng với giá tốt nhất. Giao nhanh - Miễn phí - Bảo hành 12 tháng.")" />

    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " | TechStore" : "TechStore - Điện thoại, Laptop, Phụ kiện chính hãng")</title>

    @* Preconnect for Google Fonts *@
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Roboto:wght@300;400;500;700;900&display=swap" />

    @* Favicon *@
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />

    @* Tailwind utilities are generated at build time. Existing global styles load after them. *@
    <link rel="stylesheet" href="~/css/tailwind.css" asp-append-version="true" />

    @* Global styles shared by every page. Page-specific styles are rendered below. *@
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @* Page-specific styles section *@
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <a class="skip-link" href="#main-content">Bỏ qua đến nội dung chính</a>
    <span id="page-top-sentinel" class="site-top-sentinel" aria-hidden="true"></span>

    @* ============================================================
         SITE HEADER (ViewComponent)
         The header is fixed; body has padding-top: var(--header-height)
         in base.css to prevent content from hiding under it.
    ============================================================ *@
    @await Component.InvokeAsync("Header")

    @* ============================================================
         MAIN CONTENT
    ============================================================ *@
    <main id="main-content" role="main" class="main-content">
        @RenderBody()
    </main>

    <partial name="_Footer" />
    <partial name="_AiChatbox" />
    <partial name="Partials/_ProductCardIconSprite" />
    <partial name="Partials/_SiteIconSprite" />

    <div class="toast-container" id="toast-container" role="status" aria-live="polite" aria-atomic="true"></div>

    <button id="back-to-top" aria-label="Lên đầu trang" title="Lên đầu trang">
        <span>Lên đầu</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2.4" d="M6 15l6-6 6 6"/>
        </svg>
    </button>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/components/category-menu.js" asp-append-version="true"></script>
    <script src="~/js/components/header-search.js" asp-append-version="true"></script>
    <script src="~/js/components/header-account.js" asp-append-version="true"></script>
    <script src="~/js/components/product-card.js" asp-append-version="true"></script>
    <script src="~/js/ai-chatbox.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
