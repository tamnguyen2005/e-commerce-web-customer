@model HomeHeroViewModel

<section class="home-hero-section" aria-label="Khám phá ưu đãi nổi bật">
    <div class="container">
        <div class="home-hero">
            <partial name="_HomeHeroCategorySidebar" model="Model.Categories" />

            <div class="hero-main">
                <partial name="_HomeHeroCampaignTabs" model="Model.CampaignTabs" />
                <partial name="_HomeHeroSlider" model="Model.Slides" />
                <partial name="_HomeHeroPromoGrid" model="Model.PromoTiles" />
            </div>

            <partial name="_HomeHeroUtilitySidebar" model="Model" />
        </div>
    </div>
</section>
