@model e_commerce_web_customer.Controllers.MoMoResultViewModel
@{
    ViewData["Title"] = Model.Success ? "Thanh toán thành công" : "Thanh toán thất bại";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@* Mirrors PaymentResultScreen in sportset_customer Flutter app *@

<div class="momo-result-page">
    <div class="momo-result-card">

        @* Icon — mirrors Flutter Icons.check_circle_rounded / Icons.cancel_rounded *@
        <div class="momo-result-icon @(Model.Success ? "success" : "failed")">
            @if (Model.Success)
            {
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                    <polyline points="22 4 12 14.01 9 11.01"/>
                </svg>
            }
            else
            {
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="15" y1="9" x2="9" y2="15"/>
                    <line x1="9" y1="9" x2="15" y2="15"/>
                </svg>
            }
        </div>

        @* MoMo logo badge *@
        <div class="momo-badge">
            <span class="momo-badge-dot"></span>
            MoMo
        </div>

        @* Title — mirrors Flutter Text(_isSuccess ? 'Thanh toán thành công!' : 'Thanh toán thất bại') *@
        <h1 class="momo-result-title @(Model.Success ? "success" : "failed")">
            @(Model.Success ? "Thanh toán thành công!" : "Thanh toán thất bại")
        </h1>

        @* Subtitle *@
        <p class="momo-result-subtitle">
            @if (Model.Success)
            {
                <span>Đơn hàng của bạn đã được xác nhận và đang được xử lý.</span>
            }
            else
            {
                <span>@(string.IsNullOrWhiteSpace(Model.Message) ? "Giao dịch không thể hoàn tất. Vui lòng thử lại." : Model.Message)</span>
            }
        </p>

        @* Order info card — mirrors Flutter Container with orderId *@
        <div class="momo-result-info">
            @if (!string.IsNullOrEmpty(Model.OrderId))
            {
                <div class="momo-info-row">
                    <span class="momo-info-label">Mã đơn hàng</span>
                    <span class="momo-info-value mono">@Model.OrderId</span>
                </div>
            }
            @if (!string.IsNullOrEmpty(Model.TransactionId) && Model.TransactionId != "0")
            {
                <div class="momo-info-row">
                    <span class="momo-info-label">Mã giao dịch</span>
                    <span class="momo-info-value mono">@Model.TransactionId</span>
                </div>
            }
            <div class="momo-info-row">
                <span class="momo-info-label">Cổng thanh toán</span>
                <span class="momo-info-value">
                    <span class="momo-pill">MoMo Sandbox</span>
                </span>
            </div>
            <div class="momo-info-row">
                <span class="momo-info-label">Mã kết quả</span>
                <span class="momo-info-value">@Model.ResultCode</span>
            </div>
        </div>

        @* Action buttons — mirrors Flutter ElevatedButton + OutlinedButton *@
        <div class="momo-result-actions">
            @if (Model.Success)
            {
                <a href="/" class="momo-btn primary">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                        <polyline points="9 22 9 12 15 12 15 22"/>
                    </svg>
                    Về trang chủ
                </a>
                <a href="/Account/Orders" class="momo-btn outline">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/>
                        <line x1="16" y1="13" x2="8" y2="13"/>
                        <line x1="16" y1="17" x2="8" y2="17"/>
                    </svg>
                    Xem đơn hàng
                </a>
            }
            else
            {
                <a href="/Cart" class="momo-btn primary failed-btn">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="1 4 1 10 7 10"/>
                        <path d="M3.51 15a9 9 0 102.13-9.36L1 10"/>
                    </svg>
                    Thử lại
                </a>
                <a href="/" class="momo-btn outline">
                    Quay lại trang chủ
                </a>
            }
        </div>

    </div>
</div>

@section Styles {
<style>
    .momo-result-page {
        min-height: 70vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 16px;
        background: linear-gradient(160deg, #fdf4fb 0%, #f8f8ff 100%);
    }

    .momo-result-card {
        width: 100%;
        max-width: 420px;
        background: #fff;
        border-radius: 24px;
        padding: 40px 32px 36px;
        box-shadow: 0 8px 40px rgba(0,0,0,0.08), 0 1px 4px rgba(0,0,0,0.04);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0;
        animation: slideUp 0.35s ease;
    }

    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(24px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    /* ── Icon ── */
    .momo-result-icon {
        width: 80px; height: 80px;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        margin-bottom: 16px;
    }

    .momo-result-icon svg {
        width: 40px; height: 40px;
    }

    .momo-result-icon.success {
        background: rgba(76,175,80,0.12);
        color: #4caf50;
    }

    .momo-result-icon.failed {
        background: rgba(186,26,26,0.09);
        color: #ba1a1a;
    }

    /* ── MoMo badge ── */
    .momo-badge {
        display: flex; align-items: center; gap: 6px;
        background: #fce8f3;
        color: #ae2070;
        font-size: 11px; font-weight: 700;
        letter-spacing: 0.5px;
        padding: 4px 12px;
        border-radius: 20px;
        margin-bottom: 18px;
        text-transform: uppercase;
    }

    .momo-badge-dot {
        width: 6px; height: 6px;
        background: #ae2070;
        border-radius: 50%;
    }

    /* ── Title ── */
    .momo-result-title {
        font-size: 22px; font-weight: 800;
        text-align: center;
        margin: 0 0 10px;
        letter-spacing: -0.3px;
    }

    .momo-result-title.success { color: #1b5e20; }
    .momo-result-title.failed  { color: #ba1a1a; }

    /* ── Subtitle ── */
    .momo-result-subtitle {
        font-size: 14px; color: #6b7280;
        text-align: center;
        line-height: 1.55;
        margin: 0 0 24px;
    }

    /* ── Info card ── */
    .momo-result-info {
        width: 100%;
        background: #f9f9f9;
        border-radius: 14px;
        padding: 16px;
        display: flex; flex-direction: column; gap: 10px;
        margin-bottom: 24px;
    }

    .momo-info-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: 13px;
    }

    .momo-info-label { color: #9ca3af; font-weight: 400; }

    .momo-info-value {
        color: #1a1a1a; font-weight: 600;
        text-align: right;
    }

    .momo-info-value.mono {
        font-family: 'Courier New', monospace;
        font-size: 12px;
        background: #f0f0f0;
        padding: 2px 8px; border-radius: 6px;
    }

    .momo-pill {
        background: #fce8f3; color: #ae2070;
        font-size: 11px; font-weight: 700;
        padding: 2px 10px; border-radius: 20px;
    }

    /* ── Buttons ── */
    .momo-result-actions {
        width: 100%;
        display: flex; flex-direction: column; gap: 10px;
    }

    .momo-btn {
        display: flex; align-items: center; justify-content: center;
        gap: 8px;
        width: 100%; padding: 14px;
        border-radius: 12px;
        font-size: 15px; font-weight: 700;
        text-decoration: none;
        transition: all 0.18s;
        cursor: pointer;
    }

    .momo-btn.primary {
        background: #4caf50; color: #fff;
        box-shadow: 0 4px 14px rgba(76,175,80,0.3);
    }

    .momo-btn.primary:hover {
        background: #43a047;
        transform: translateY(-1px);
        box-shadow: 0 6px 18px rgba(76,175,80,0.4);
    }

    .momo-btn.primary.failed-btn {
        background: #ae2070;
        box-shadow: 0 4px 14px rgba(174,32,112,0.3);
    }

    .momo-btn.primary.failed-btn:hover {
        background: #8b1a59;
    }

    .momo-btn.outline {
        background: transparent;
        color: #1b5e20;
        border: 1.5px solid #4caf50;
    }

    .momo-btn.outline:hover {
        background: rgba(76,175,80,0.06);
    }

    @@media (max-width: 480px) {
        .momo-result-card { padding: 32px 20px 28px; }
        .momo-result-title { font-size: 20px; }
    }
</style>
}
